{
  "manifest_version": 3,
  "name": "Aegis Email Gateway (Gmail Integration)",
  "version": "1.0",
  "description": "Real-time email security system providing dynamic threat analysis within Gmail.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["*://mail.google.com/*", "http://127.0.0.1:5000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ]
}
